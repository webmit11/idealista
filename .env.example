# ---- App ----
APP_NAME=Porto Investment Finder
APP_HOST=0.0.0.0
APP_PORT=8000

# ---- Auth (HTTP Basic) ----
# Set a password to require login (everything except /health). Empty = open.
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=

# Host ports published by docker-compose.
# The app is served via the nginx proxy at http://idealista.localhost
# Change PROXY_PORT if 80 is busy (then use http://idealista.localhost:PORT).
PROXY_PORT=80
HOST_DB_PORT=5432
DEBUG=false
LOG_LEVEL=INFO
LOG_JSON=true

# ---- Database ----
# Docker Compose default (the `db` service):
DATABASE_URL=postgresql+psycopg2://idealista:idealista@db:5432/idealista
# Local run without Postgres (uncomment to use SQLite):
# DATABASE_URL=sqlite:///./dev.db

# Used by the Postgres container in docker-compose:
POSTGRES_USER=idealista
POSTGRES_PASSWORD=idealista
POSTGRES_DB=idealista

# ---- Apify (Idealista scraper) ----
APIFY_TOKEN=
APIFY_ACTOR_ID=igolaizola~idealista-scraper
# Idealista search URLs, separated by SPACES or newlines (NOT commas — Idealista
# URLs contain commas). Used when no URL is passed to the import.
APIFY_SEARCH_URLS=
APIFY_MAX_ITEMS=200
APIFY_COUNTRY=pt
APIFY_TIMEOUT_S=300
# Drop new-development project listings (/empreendimento/), keep single resale units:
APIFY_EXCLUDE_NEW_DEVELOPMENTS=true
# Drop houses (chalet/countryHouse/moradia) — keep only apartments:
APIFY_EXCLUDE_HOUSES=true

# ---- Geo / metro ----
WALKING_SPEED_M_PER_MIN=80

# ---- Scoring / benchmark ----
BENCHMARK_MIN_SAMPLES=3
NEW_LISTING_DAYS=7
# Default min score on the dashboard (blank field -> this; type 0 to see all):
DASHBOARD_MIN_SCORE=50
# Multiply metro score by this when location is approximate (hidden address); 1.0 = off:
APPROX_LOCATION_METRO_FACTOR=0.7
# Bonus points for south-facing windows / orientation (0 = off):
SOUTH_FACING_BONUS=4
# Extra bad-neighbourhood keywords (comma-separated), added to the built-in list
# in app/services/bad_neighborhoods.py. Matched against zona/parish/address/text.
BAD_NEIGHBORHOODS=

# ---- Alerts (new hits + price drops) ----
ALERTS_ENABLED=false
ALERT_CHANNEL=auto            # auto | telegram | email | none
ALERT_MIN_SCORE=75
ALERT_MIN_PRICE_DROP=5        # percent
APP_BASE_URL=http://idealista.localhost
# Telegram (from @BotFather; chat id from @userinfobot or getUpdates):
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Mini App: only this Telegram user id may open the app (exclusive use). Empty = any valid TG user.
TELEGRAM_OWNER_ID=
# Email / SMTP (alternative to Telegram):
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TLS=true
ALERT_EMAIL_TO=

# ---- Refresh coverage ----
# Results per area for the manual button + scheduled refresh. Higher = fuller
# coverage and reliable delisting on big areas (more Apify credits).
MANUAL_REFRESH_MAX_ITEMS=500

# ---- Scheduler ----
SCHEDULER_ENABLED=false
SCHEDULER_PROVIDER=mock
DAILY_IMPORT_HOUR=6
DAILY_IMPORT_MINUTE=0

# ---- Misc ----
MOCK_DATA_PATH=sample_data/properties_mock.json
RAW_DATA_DIR=data/raw
AUTO_CREATE_TABLES=true
